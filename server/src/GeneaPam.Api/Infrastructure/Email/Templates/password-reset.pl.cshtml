@model GeneaPam.Api.Infrastructure.Email.PasswordResetEmailModel
<!DOCTYPE html>
<html lang="pl">
<head><meta charset="utf-8"><title>Resetowanie hasła</title></head>
<body>
  <h1>Prośba o reset hasła</h1>
  <p>Cześć, @Model.UserName,</p>
  <p>Kliknij poniższy link, aby zresetować hasło. Link wygaśnie za @Model.ExpiryHours godzin.</p>
  <p><a href="@Model.ResetLink">Zresetuj hasło</a></p>
  <p>Jeśli nie prosiłeś o reset hasła, zignoruj tę wiadomość.</p>
</body>
</html>
